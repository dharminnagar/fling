{
  "name": "@dharminnagar/fling",
  "version": "1.2.0",
  "description": "Deploy a single HTML file to your Cloudflare subdomain in one command",
  "type": "module",
  "bin": {
    "fling": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "link": "npm run build && npm link",
    "publish": "npm run build && npm publish"
  },
  "keywords": [
    "cloudflare",
    "deploy",
    "html",
    "cli",
    "static",
    "hosting"
  ],
  "author": "Dharmin Nagar <dharminnagar@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dharminnagar/fling"
  },
  "homepage": "https://github.com/dharminnagar/fling#readme",
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
